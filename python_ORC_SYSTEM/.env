# OpenRouter API Configuration
OPENROUTER_API_KEY=
# PRIMARY: Ollama (Local, Free, Fast)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
ENABLE_OLLAMA=true

# SECONDARY: OpenRouter (Cloud Backup - only if Ollama fails)
 # Optional
OPENROUTER_MODEL=stepfun/step-3.5-flash
ENABLE_OPENROUTER=true

# LAST RESORT: Regex (Always works, no AI needed)
ENABLE_REGEX_FALLBACK=true


# Other settings
AI_PROVIDER=auto
ENABLE_AI_ANALYSIS=true
SITE_URL=http://localhost:8000
SITE_NAME=Finance OCR Service
DEBUG=false

